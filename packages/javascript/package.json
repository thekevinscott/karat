{
  "name": "coaxer",
  "version": "0.0.0",
  "description": "Label examples. Derive the prompt. Consume it as a string.",
  "homepage": "https://thekevinscott.github.io/coaxer/",
  "bugs": {
    "url": "https://github.com/thekevinscott/coaxer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekevinscott/coaxer.git",
    "directory": "packages/javascript"
  },
  "license": "MIT",
  "author": "Kevin Scott",
  "keywords": [
    "prompt",
    "prompt-engineering",
    "llm",
    "anthropic",
    "openai",
    "structured-output",
    "zod"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "coax": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:cov": "vitest run --coverage",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm run test:cov"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@biomejs/biome": "2.4.14",
    "@types/node": "^20.0.0",
    "@types/nunjucks": "^3.2.6",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
